# SET-UP
ENVIRONMENT="production"

# APP LOGIC
BATCH_SIZE=15
QUEUE_MIN_CAPACITY=5
LEARNING_RATE=0.05
NORM_CAP=10.0
OVER_FETCH_FACTOR=2

# REDIS
REDIS_URL="redis://redis:6379"

# NEO4J (running in Docker on EC2 — using dev-password for simplicity)
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="dev-password"
NEO4J_DATABASE="neo4j"

# DB — host + key injected by sync script from terraform outputs (leave empty here)
DB_HOST=""
DB_PORT="5432"
DB_NAME="app_db"
DB_SYNC_DRIVER="postgresql+psycopg2"
DB_ASYNC_DRIVER="postgresql+asyncpg"
# DB_USER and DB_PASSWORD are NOT set here — AppSettings fetches them from Secrets Manager

# AWS
AWS_MAIN_REGION="us-east-1"

# TMDB
TMDB_API_KEY=""
TMDB_API_READ_ACCESS_TOKEN=""
TMDB_IMG_URL="https://image.tmdb.org/t/p/w500"
TMDB_BASE_URL="https://api.themoviedb.org/3"

# FIREBASE
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_CLIENT_ID=""
FIREBASE_WEB_API_KEY=""

# GRAFANA
GF_SECURITY_ADMIN_PASSWORD=""

# DISCORD (two webhooks — one for Grafana alerts, one for pipeline notifier)
DISCORD_WEBHOOK_GRAFANA=""
DISCORD_WEBHOOK_PIPELINE=""
