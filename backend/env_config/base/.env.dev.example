# 1) CONFIG
## SET-UP
ENVIRONMENT="dev"

## REDIS
REDIS_URL="redis://redis:6379"

## NEO4J
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="dev-password"
NEO4J_DATABASE="neo4j"

## APP LOGIC
BATCH_SIZE=15
QUEUE_MIN_CAPACITY=5
LEARNING_RATE=0.05
NORM_CAP=10.0
OVER_FETCH_FACTOR=2

# 2) SECRETS
